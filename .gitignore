# Dependencies / build output
node_modules/
.angular/
dist/

# Secrets — never commit these. Real values go in .env (local) or
# Render's Environment Variables dashboard (deploy).
.env
.env.*
!.env.example

# These two files are AUTO-GENERATED by scripts/generate-env.js from
# environment variables — they contain real keys after generation, so
# they must never be committed even though they live under src/.
src/environments/environment.ts
src/environments/environment.prod.ts

# Misc
*.log
.DS_Store
